# Grouping Vehicle Age
df$VehAgeBand <- as.numeric(as.character(df$VehAge))
df$VehAgeBand <- cut(
  df$VehAge,
  breaks = c(-Inf, 1, 4, 7, 10, 20, Inf),
  labels = c("0-1", "2-4", "5-7", "8-10", "11-20", "21+"),
  include.lowest = TRUE
)

# Grouping Vehicle Power
df$VehPowerBand <- as.numeric(as.character(df$VehPower))
df$VehPowerBand <- cut(
  df$VehPower,
  breaks = c(-Inf, 5, 7, 10, Inf),
  labels = c("4-5", "5-7", "7-10", "10+"),
  include.lowest = TRUE
)

# Grouping Density as an Ordinal Variable
df$DensityBand <- as.numeric(as.character(df$Density))
df$DensityBand <- cut(
  df$Density,
  breaks = 5,
  labels = c("Low", "Low-Medium", "Medium", "Medium-High", "High"),
  include.lowest = TRUE
)

# Count distribution over VehAge and DrivAge bands
VehAgeFreq = df %>%
  count(VehAgeBand)
VehAgeFreq

DrivAgeFreq = df %>%
  count(DrivAgeBand)
DrivAgeFreq

