set.seed(124)

# Removing extraneous features and features with added bands
df_drop <- df %>% dplyr::select(-BonusMalus, -DrivAge, -VehAge, -VehPower, -Density, -Frequency, -LogDensity, -IDpol, -Region)

# 80%/20% Train/Test split, stratifying by ClaimNb
df_split <- initial_split(df_drop, prop = 0.80, strata = ClaimNb)
train = training(df_split)
test = testing(df_split)

# Comparing train/test portfolio frequency
cat("Training Claim Frequency: ", sum(train$ClaimNb) / sum(train$Exposure), "\n")
cat("Test Claim Frequency: ", sum(test$ClaimNb) / sum(test$Exposure))

