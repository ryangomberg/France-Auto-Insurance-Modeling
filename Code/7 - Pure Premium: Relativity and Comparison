# Predicting on Test Set - Freq x Sev
freq_pred <- predict(FreqPoisson,
                     newdata = test,
                     type = "response")
nb_pred <- predict(FreqNB,
                     newdata = test,
                     type = "response")
sev_pred <- predict(sevGamma,
                    newdata = test,
                    type = "response")
pp_pred_freqsev <- (freq_pred / test$Exposure) * sev_pred

# Predicting on Test Set - Tweedie
tweedie_pred <- predict(tweedie_glm16,
                        newdata = test,
                        type = "response")

# Computing true pure premium
pp_actual = test$PurePremium

# Portfolio-level comparisons
total_actual = sum(pp_actual * test$Exposure)
total_fs = sum(pp_pred_freqsev * test$Exposure)
total_tweedie = sum(tweedie_pred * test$Exposure)

# Printing actual, FreqxSev, Tweedie pure premiums
cat("Test Set - Portfolio Level Comparison: ", "\n")
cat("Actual total premium amount: ", total_actual, "\n")
cat("Predicted FreqxSev amount: ", total_fs, ", Ratio of actual: ", total_fs/total_actual, "\n")
cat("Predicted Tweedie amount: ", total_tweedie, ", Ratio of actual: ", total_tweedie/total_actual, "\n")

# Weighted Mean Absolute Error
weights = test$Exposure
MAE_fs = weighted.mean(abs(pp_actual - pp_pred_freqsev), weights)
MAE_tweedie = weighted.mean(abs(pp_actual - tweedie_pred), weights)
cat("MAE: FreqxSev: ", MAE_fs, "\n")
cat("MAE: Tweedie: ", MAE_tweedie)

