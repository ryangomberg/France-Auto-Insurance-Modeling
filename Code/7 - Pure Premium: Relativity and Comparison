# Pure Premium bar graph
# Legend for FreqxSev, Tweedie, and Observed
# Bar plots for DrivAge, BonusMalus, VehAge,
# VehPower, Area, and VehGas

observed <- test$Claim.Amount / test$Exposure

vars <- c(
  "Driver Age" = "DrivAgeBand",
  "Bonus/Malus" = "BonusMalusBand",
  "Vehicle Age" = "VehAgeBand",
  "Vehicle Power" = "VehPowerBand",
  "Area" = "Area",
  "Vehicle Brand" = "VehBrand"
)

all_plots <- map2_dfr(
  names(vars),
  vars,
  ~{
    var_name <- .x
    var_col  <- .y

    data_pp <- data.frame(
      Band = test[[var_col]],
      Observed = observed,
      FreqSev = pp_pred_freqsev,
      Tweedie = tweedie_pred
    )

  data_pp <- data_pp %>%
      mutate(
        Band = case_when(
          var_col == "BonusMalusBand" ~ factor(
            as.character(Band),
            levels = c("50-60","61-70","71-80","81-90","91-100","101-150")
          ),
          var_col == "VehAgeBand" ~ factor(
            as.character(Band),
            levels = c("0-1","2-4","5-7","8-10","11-20","21+")
          ),
          var_col == "VehPowerBand" ~ factor(
            as.character(Band),
            levels = c("5-7","4-5","7-10","10+")
          ),
          TRUE ~ factor(as.character(Band))
        )
      )

    data_pp %>%
      filter(!is.na(Band)) %>%
      group_by(Band) %>%
      summarise(
        Observed = mean(Observed),
        FreqSev = mean(FreqSev),
        Tweedie = mean(Tweedie),
        .groups = "drop"
      ) %>%
      pivot_longer(
        cols = c(Observed, FreqSev, Tweedie),
        names_to = "Model",
        values_to = "PurePremium"
      ) %>%
      mutate(Variable = var_name)
  }
)

ggplot(all_plots,
       aes(x = Band,
           y = PurePremium,
           fill = Model)) +
  geom_col(
    position = position_dodge(width = 0.8),
    width = 0.7
  ) +
  scale_fill_manual(
    values = c(
      Observed = "darkseagreen2",
      FreqSev = "coral",
      Tweedie = "cyan4"
    )
  ) +
  facet_wrap(
    ~Variable,
    nrow = 2,
    ncol = 3,
    scales = "free_x"
  ) +
  labs(
    x = NULL,
    y = "Pure Premium"
  ) +
  theme_minimal() +
  theme(
    legend.title = element_blank(),
    axis.text.x = element_text(
      angle = 45,
      hjust = 1
    ),
    strip.text = element_text(
      size = 13,
      face = "bold"
    )
  )

