# Building Poisson GLM, log-link
# Removing structurally related variables
# Add Exposure offset term
FreqPoisson <- glm(
  ClaimNb ~ . - Exposure - AvgClaimAmount - PurePremium - Claim.Amount,
  offset = log(Exposure),
  family = poisson(link = "log"),
  data = train
)

poistable = summary(FreqPoisson)
poistable

--------------------------

# Summarizing GLM Coefficients
# Add Relativity 
coef_table <- data.frame(
  Variable = rownames(poistable$coefficients),
  Coefficient = round(poistable$coefficients[, "Estimate"], 4),
  Relativity = round(exp(poistable$coefficients[, "Estimate"]), 2),
  `Std. Error` = round(poistable$coefficients[, "Std. Error"], 2),
  `z value` = round(poistable$coefficients[, "z value"], 2),
  `Pr(>|z|)` = round(poistable$coefficients[, "Pr(>|z|)"], 2)
)
coef_table

--------------------------

# Poisson (Frequency) Relativity vertical bar graphs for
# Area, DrivAge bands, VehAge bands, BonusMalus bands,
# VehPower bands, VehGas
# Vertical dashed line at 1.0 is the reference 
# relativity (no change)

area_plot <- coef_table %>%
  filter(grepl("^Area", Variable)) %>%
  mutate(
    Area = sub("Area", "", Variable)
  ) %>%
  dplyr::select(Area, Relativity)

# Add base category
area_plot <- bind_rows(
  data.frame(Area = "A (Base)", Relativity = 1),
  area_plot
)

# Keep areas in order
area_plot$Area <- factor(area_plot$Area,
                         levels = c("A (Base)","B","C","D","E","F"))

xmax <- max(area_plot$Relativity)
ggplot(area_plot,
       aes(x = Relativity,
           y = Area)) +
  geom_col(fill = "skyblue") +
  geom_vline(xintercept = 1,
             linetype = "dashed",
             color = "red",
             linewidth = 0.8) +
  coord_cartesian(xlim = c(0, xmax + 0.25)) +
  labs(
    x = "Relativity",
    y = "Area",
    title = "Area Relativities"
  ) +
  geom_text(aes(label = sprintf("%.3f", Relativity)),
          family = "serif", hjust = -0.3, color = "black", size = 4) +
  theme(text = element_text(family = "serif"))

