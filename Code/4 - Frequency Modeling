# Fitting Negative Binomial GLM with log-link
# Removing structurally related variables
# Add Exposure offset term
FreqNB <- glm.nb(ClaimNb ~ . - Exposure - PurePremium - AvgClaimAmount - Claim.Amount + offset(log(Exposure)), data = train)
nbtable <- summary(FreqNB)

--------------------------

# Summarizing Negative Binomial GLM Coefficients
coef_table_nb <- data.frame(
  Variable = rownames(nbtable$coefficients),
  Coefficient = round(nbtable$coefficients[, "Estimate"], 4),
  Relativity = round(exp(nbtable$coefficients[, "Estimate"]), 2),
  `Std. Error` = round(nbtable$coefficients[, "Std. Error"], 2),
  `z value` = round(nbtable$coefficients[, "z value"], 2),
  `Pr(>|z|)` = round(nbtable$coefficients[, "Pr(>|z|)"], 2)
)
coef_table_nb

--------------------------

# Negative binomial - Overdispersion parameter and
# checking for significance

check_overdispersion(FreqNB)

--------------------------

# Relativity comparison between Poisson and Negative Binomial

relativity_comp <- data.frame(
  PoissonRelativity = round(exp(poistable$coefficients[, "Estimate"]), 2),
  NBRelativity = round(exp(nbtable$coefficients[, "Estimate"]), 2))
relativity_comp

--------------------------

# AIC extraction from Poisson and Negative Binomial
# Output the model with the lowest AIC

cat("Poisson AIC: ", AIC(FreqPoisson), "\n")
cat("Negative Binomial AIC: ", AIC(FreqNB), "\n")
if(AIC(FreqPoisson) > AIC(FreqNB)) {
  cat("Better Model: Negative Binomial")
} else {
  cat("Better model: Poisson")
}

