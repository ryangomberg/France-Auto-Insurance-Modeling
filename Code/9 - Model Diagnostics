# Lorenz Curve and Gini Coefficient Estimation
lorenz_curve <- function(exposure, claims, prediction) {

  df <- data.frame(
    Exposure = exposure,
    Claims = claims,
    Prediction = prediction
  )

  df <- df[order(df$Prediction), ]

  df$CumExposure <- cumsum(df$Exposure) / sum(df$Exposure)
  df$CumClaims   <- cumsum(df$Claims) / sum(df$Claims)

  df
}

freq_curve <- lorenz_curve(
  exposure = test$Exposure,
  claims = test$Claim.Amount,
  prediction = pp_pred_freqsev
)

tweed_curve <- lorenz_curve(
  exposure = test$Exposure,
  claims = test$Claim.Amount,
  prediction = tweedie_pred
)

lorenz_gini <- function(curve) {

  x <- c(0, curve$CumExposure)
  y <- c(0, curve$CumClaims)

  area <- sum(diff(x) * (head(y,-1) + tail(y,-1))/2)
  1 - 2 * area
}

gini_freq <- lorenz_gini(freq_curve)
gini_tweed <- lorenz_gini(tweed_curve)

cat("FreqxSev Gini: ", gini_freq, "\n")
cat("Tweedie (p = 1.6) Gini: ", gini_tweed, "\n")

ggplot() +
  geom_line(aes(x = c(0,1), y = c(0,1)),
            linetype = "dashed",
            color = "gray50") +

  geom_line(data = freq_curve,
            aes(CumExposure, CumClaims,
                color = "Freq × Sev"),
            linewidth = 1.2) +

  geom_line(data = tweed_curve,
            aes(CumExposure, CumClaims,
                color = "Tweedie"),
            linewidth = 1.2) +

  scale_color_manual(values = c(
    "Freq × Sev" = "#2C7FB8",
    "Tweedie" = "#C51B7D"
  )) +

  labs(
    title = "Ordered Lorenz Curves",
    x = "Cumulative Share of Exposure",
    y = "Cumulative Share of Claims",
    color = ""
  ) 

