# Lift Charts
# FreqxSev
lift_fs <- data.frame(
  Observed = observed,
  Predicted = pp_pred_freqsev
) %>%
  mutate(
    Decile = ntile(Predicted, 10)
  ) %>%
  group_by(Decile) %>%
  summarise(
    Actual = mean(Observed, na.rm = TRUE),
    Predicted = mean(Predicted, na.rm = TRUE)
  )

lift_long <- lift_fs %>%
  pivot_longer(-Decile,
               names_to = "Type",
               values_to = "Premium")

ggplot(lift_long,
       aes(x = factor(Decile),
           y = Premium,
           fill = Type)) +
  geom_col(position = "dodge") +
  labs(
    title = "Lift Chart — Frequency × Severity",
    x = "Predicted Premium Decile (1 = cheapest, 10 = most expensive)",
    y = "Average Pure Premium"
  ) +
  theme_minimal()

