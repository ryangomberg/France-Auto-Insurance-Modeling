9 - Model Diagnostics


# Poisson Diagnostics
# Residual vs. Fitted
ggplot(data.frame(
  Fitted = fitted(FreqPoisson),
  Residuals = residuals(FreqPoisson, type = "deviance")
), aes(x = Fitted, y = Residuals)) +
  geom_point(alpha = 0.4) +
  geom_hline(yintercept = 0, linetype = "dashed", color = "red") +
  labs(
    title = "Residuals vs Fitted",
    x = "Fitted Values",
    y = "Deviance Residuals"
  )

# QQ-plot
qqnorm(residuals(FreqPoisson, type = "deviance"))
qqline(residuals(FreqPoisson, type = "deviance"),
       col = "red",
       lwd = 2)

# Residual distribution
res <- residuals(FreqPoisson, type = "deviance")

ggplot(data.frame(res), aes(x = res)) +
  geom_histogram(aes(y = after_stat(density)),
                 bins = 30,
                 fill = "skyblue",
                 color = "white",
                 alpha = 0.8) +
  stat_function(
    aes(color = "N(0,1)"),
    fun = dnorm,
    args = list(mean = 0, sd = 1),
    linewidth = 1
  ) +
  scale_color_manual(values = c("N(0,1)" = "red"), name = "") +
  labs(
    title = "Poisson: Residual Distribution",
    x = "Deviance Residuals",
    y = "Density"
  )
