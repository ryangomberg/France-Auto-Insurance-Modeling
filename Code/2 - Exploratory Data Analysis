# Adding bands to DrivAge and BonusMalus
df$DrivAgeBand <- as.numeric(as.character(df$DrivAge))
df$DrivAgeBand <- cut(
  df$DrivAge,
  breaks = c(-Inf, 25, 35, 45, 55, 65, 75, Inf),
  labels = c("18-25", "26-35", "36-45", "46-55", "56-65", "66-75", "75+"),
  include.lowest = TRUE
)

df$BonusMalusBand <- cut(
  as.numeric(df$BonusMalus),
  breaks = c(-Inf, 60, 70, 80, 90, 100, Inf),
  labels = c("50-60", "61-70", "71-80", "81-90", "91-100", "101-150"),
  include.lowest = TRUE
)

# Observed Frequency by Rating Factor chart for:
# Area, DrivAge, BonusMalus, VehPower, VehGas
area_freq <- df %>%
  group_by(Area) %>%
  summarise(
    Frequency = sum(ClaimNb) / sum(Exposure),
    Exposure = sum(Exposure)
  )

da_freq <- df %>%
  group_by(DrivAgeBand) %>%
  summarise(
    Frequency = sum(ClaimNb) / sum(Exposure),
    Exposure = sum(Exposure)
  )

bm_freq <- df %>%
  group_by(BonusMalusBand) %>%
  summarise(
    Frequency = sum(ClaimNb) / sum(Exposure),
    Exposure = sum(Exposure)
  )

vp_freq <- df %>%
  group_by(VehPower) %>%
  summarise(
    Frequency = sum(ClaimNb) / sum(Exposure),
    Exposure = sum(Exposure)
  )

vg_freq <- df %>%
  group_by(VehGas) %>%
  summarise(
    Frequency = sum(ClaimNb) / sum(Exposure),
    Exposure = sum(Exposure)
  )

scale <- max(area_freq$Exposure) / max(area_freq$Frequency)
ggplot(area_freq, aes(x = Area)) +
  geom_col(aes(y = Exposure / scale), fill = "grey", width = 0.8) +
  geom_line(aes(y = Frequency, group = 1), color = "skyblue", linewidth = 1) +
  geom_point(aes(y = Frequency), color = "skyblue", size = 2) +
  geom_hline(yintercept = sum(df$ClaimNb)/sum(df$Exposure), color = "red", linetype = "dashed") +
  scale_y_continuous(
    name = "Claim Frequency",
    sec.axis = sec_axis(~ . * scale, name = "Exposure")
  )

