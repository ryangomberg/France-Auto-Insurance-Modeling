# Initializating a fixed sample
set.seed(123)

# BonusMalus count over respective bands
ggplot(df, aes(x = BonusMalusBand)) +
  geom_bar(color = "black", fill = "skyblue", width = 0.5) +
  geom_text(stat = "count", aes(label = after_stat(count)), vjust = -0.5)

# BonusMalus spread over DrivAge
sample_bm <- df |> slice_sample(prop = 0.10)
ggplot(data = sample_bm, mapping = aes(x = DrivAge, y = BonusMalus)) +
  geom_point(color = "blue", size = 2) +
  labs(title = "BonusMalus vs. DrivAge (10% Sample)",
       x = "DrivAge (in years)",
       y = "Bonus/Malus")

