# Filtering by a positive number of claims
posclaims <- df %>% filter(!(ClaimNb == 0))

# Claim Severity Distribution over AvgClaimAmount
ggplot(posclaims, aes(x = AvgClaimAmount)) +
  geom_histogram(bins = 70, fill = "white", color = "black") +
  labs(title = "Claim Severity Distribution", x = "Average Severity", 
       y = "count")

# Claim Severity Distribution over Log(AvgClaimAmount)
LogArr <- log(posclaims$AvgClaimAmount)
ggplot(posclaims, aes(x = LogArr)) +
  geom_histogram(bins = 70, fill = "white", color = "black") +
  labs(title = "Claim Severity Distribution", x = "Log Average Severity", 
       y = "count")

# For ClaimNb > 0: Mean, Median, Maximum, Standard Deviation
cat("Severity Statistics for positive claim frequency: ", "\n")
cat("  Mean: ", mean(posclaims$AvgClaimAmount), "\n")
cat("  Median: ", median(posclaims$AvgClaimAmount), "\n")
cat("  Max: ", max(posclaims$AvgClaimAmount), "\n")
cat("  Standard Deviation: ", sd(posclaims$AvgClaimAmount))

