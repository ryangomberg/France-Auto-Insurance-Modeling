# Example Policy: 45 year-old driver, BonusMalus 60, VehAge 8 years, VehPower 5, Area E, VehBrand B12, Medium Density, Diesel

policy_ex <- data.frame(
  DrivAgeBand = "36-45",
  BonusMalusBand = "50-60",
  VehAgeBand = "8-10",
  Area = "E",
  VehBrand = "B12",
  VehPowerBand = "5-7",
  VehGas = "Diesel",
  DensityBand = "Medium",
  Claim.Amount = 0,
  AvgClaimAmount = 0,
  PurePremium = 0,
  ClaimNb = 0,
  Exposure = 1
)

# Output expected frequency, average severity, and pure premium
pred_freq_ex <- predict(FreqPoisson, 
                        newdata = policy_ex,
                        type = "response")

pred_sev_ex <- predict(sevGamma,
                       newdata = policy_ex,
                       type = "response")

pred_pp_ex <- pred_freq_ex * pred_sev_ex
cat("Expected Annual Frequency: ", pred_freq_ex, " claims per year", "\n")
cat("Expected Average Severity: ", pred_sev_ex, "\n")
cat("Expected Pure Premium: ", pred_pp_ex)

