# Final Rating Relativities for frequency, severity,
# among bands for DrivAge, VehAge, Area, VehPower,
# BonusMalus, and VehGas

models <- list(
  Frequency = FreqPoisson,
  Severity = sevGamma,
  Tweedie = tweedie_glm16
)

cat_vars <- c(
  "DrivAgeBand",
  "VehAgeBand",
  "Area",
  "VehPowerBand",
  "BonusMalusBand",
  "VehBrand"
)

# Obtain relativities for each models' coefficients
get_rel <- function(model, var) {
  coefs <- coef(summary(model))
  idx <- grepl(paste0("^", var), rownames(coefs))

  rel <- exp(coefs[idx, "Estimate"])
  names(rel) <- sub(paste0("^", var), "", names(rel))
  rel
}

# Compile relativities for each categorical variable from
# every fitted model into a data frame
plot_df <- bind_rows(
  lapply(cat_vars, function(v) {
    bind_rows(
      lapply(names(models), function(m) {
        data.frame(
          Variable = v,
          Level = names(get_rel(models[[m]], v)),
          Relativity = as.numeric(get_rel(models[[m]], v)),
          Model = m
        )
      })
    )
  })
)

# Adding base class for each categorical feature
base_levels <- data.frame(
  Variable = c(
    "Area",
    "BonusMalusBand",
    "DrivAgeBand",
    "VehAgeBand",
    "VehPowerBand",
    "VehBrand"
  ),
  Level = c(
    "A",
    "50-60",
    "18-25",
    "0-1",
    "4-5",
    "B1"
  )
)

# Merging base levels from each categorical variable
base_df <- merge(
  base_levels,
  data.frame(Model = names(models)),
  by = NULL
)

# Relativity for each base level is 1
base_df$Relativity <- 1

# Appends base levels and the others
plot_df <- bind_rows(base_df, plot_df)

# Express BonusMalus, VehAge, VehPower as factors
# for plotting
plot_df <- plot_df %>%
  mutate(
    Level = case_when(
      Variable == "BonusMalusBand" ~ factor(
        as.character(Level),
        levels = c("50-60","61-70","71-80","81-90","91-100","101-150")
      ),

      Variable == "VehAgeBand" ~ factor(
        as.character(Level),
        levels = c("0-1","2-4","5-7","8-10","11-20","21+")
      ),

      Variable == "VehPowerBand" ~ factor(
        as.character(Level),
        levels = c("4-5","5-7","7-10","10+")
      ),

      TRUE ~ factor(as.character(Level))
    )
  )

# Dashed line at 1 is the base relativity
ggplot(plot_df,
       aes(x = Level,
           y = Relativity,
           fill = Model)) +
  geom_col(position = "dodge") +
  geom_hline(yintercept = 1,
             colour = "red",
             linetype = "dashed") +
  facet_wrap(~ Variable, scales = "free_x") +
  theme_minimal() +
  theme(
    axis.text.x = element_text(angle = 45, hjust = 1)
  )

