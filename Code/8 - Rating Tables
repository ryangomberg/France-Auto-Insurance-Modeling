# Base Frequency 
# Poisson Rating Table
# Each table will have the relativity for each feature band as well
# as their significance level
cat("Base Frequency: ", exp(coef(FreqPoisson)[1]))

poiscoef_sum <- coef(poistable)
idx <- grepl("^DrivAgeBand", rownames(poiscoef_sum))
age_coefs <- poiscoef_sum[idx, ]
rel_age <- exp(age_coefs[, "Estimate"])
pval_age <- age_coefs[, "Pr(>|z|)"]

stars_age <- symnum(
  pval_age,
  corr = FALSE,
  cutpoints = c(0, .001, .01, .05, .1, 1),
  symbols = c("***", "**", "*", ".", "")
)

age_rating <- data.frame(
  Relativity = round(rel_age, 4),
  Signif = stars_age
)

ref_age <- data.frame(
  Relativity = 1,
  Signif = ""
)
rownames(ref_age) <- "(reference level)"

age_rating <- rbind(ref_age, age_rating)
rownames(age_rating)[-1] <- sub("^DrivAgeBand", "", rownames(age_rating)[-1])
age_rating

