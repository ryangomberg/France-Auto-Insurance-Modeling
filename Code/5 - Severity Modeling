# Removing policies with zero claims
df_pos <- df_drop %>% 
  filter(!(AvgClaimAmount == 0))

# 80%/20% split on severity test/train set
pos_split <- initial_split(df_pos, prop = 0.8)
train_sev = training(pos_split)
test_sev = testing(pos_split)

# Train and test severity comparison
cat("Average severity (train): ", mean(train_sev$AvgClaimAmount), "\n")
cat("Average severity (test): ", mean(test_sev$AvgClaimAmount), "\n")

--------------------------

# Fitting Gamma GLM to severity data
# Removing structurally related variables
# Log-link 
sevGamma <- glm(AvgClaimAmount ~ . -PurePremium - Exposure - ClaimNb - Claim.Amount,
               family = Gamma(link = "log"),
               data = train_sev)

gamma_sum <- summary(sevGamma)
gamma_sum

--------------------------

# Summarizing Gamma GLM Coefficients
gamma_table <- data.frame(
  Variable = rownames(gamma_sum$coefficients),
  Coefficient = round(gamma_sum$coefficients[, "Estimate"], 4),
  Relativity = round(exp(gamma_sum$coefficients[, "Estimate"]), 2),
  `Std. Error` = round(gamma_sum$coefficients[, "Std. Error"], 2),
  `t value` = round(gamma_sum$coefficients[, "t value"], 2),
  `Pr(>|t|)` = round(gamma_sum$coefficients[, "Pr(>|t|)"], 3)
)
gamma_table

