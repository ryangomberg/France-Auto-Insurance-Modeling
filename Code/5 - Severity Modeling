# Gamma (Severity) Relativity vertical bar graphs for
# Area, DrivAge bands, VehAge bands, BonusMalus bands,
# VehPower bands, VehGas
# Vertical dashed line at 1.0 is the reference 
# relativity (no change)

area_gamma <- gamma_table %>%
  filter(grepl("^Area", Variable)) %>%
  mutate(
    Area = sub("Area", "", Variable)
  ) %>%
  dplyr::select(Area, Relativity)

# Add base category
area_gamma <- bind_rows(
  data.frame(Area = "A (Base)", Relativity = 1),
  area_gamma
)

# Keep areas in order
area_gamma$Area <- factor(area_gamma$Area,
                         levels = c("A (Base)","B","C","D","E","F"))

xmax <- max(area_gamma$Relativity)
ggplot(area_gamma,
       aes(x = Relativity,
           y = Area)) +
  geom_col(fill = "skyblue") +
  geom_vline(xintercept = 1,
             linetype = "dashed",
             color = "red",
             linewidth = 0.8) +
  coord_cartesian(xlim = c(0, xmax + 0.25)) +
  labs(
    x = "Relativity",
    y = "Area",
    title = "Area Relativities: Severity"
  ) +
  geom_text(aes(label = sprintf("%.3f", Relativity)),
          family = "serif", hjust = -0.3, color = "black", size = 4) +
  theme(text = element_text(family = "serif"))


